<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="#F5F5F5">

    <TextView
        android:id="@+id/title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="AutiCare"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#3F51B5"
        android:layout_marginBottom="40dp"/>

    <Button
        android:id="@+id/btnCommunication"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Visual Communication"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnRoutine"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Daily Routine"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnEmotion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Emotion Tracker"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnMedicine"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Medicine Reminder"/>

</LinearLayout>