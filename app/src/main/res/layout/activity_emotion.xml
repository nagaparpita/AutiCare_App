<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F8FF">

    <!-- Top Bar -->
    <View
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="#1A1A1A"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/backBtn"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="8dp"
        android:padding="12dp"
        android:src="@drawable/ic_arrow_back"
        app:layout_constraintBottom_toBottomOf="@id/topBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/topBar"
        app:tint="@color/white" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="AutiCare"
        android:textColor="@color/white"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/topBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/topBar" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topBar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Select Emotion"
                android:textColor="#1A237E"
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_marginBottom="24dp"/>

            <!-- Happy Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/happyBtn"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:layout_marginBottom="16dp"
                android:backgroundTint="@null"
                android:background="@drawable/bg_happy_btn"
                android:text="Happy"
                android:textAllCaps="false"
                android:textColor="#002244"
                android:textSize="22sp"
                android:textStyle="bold"
                app:icon="@drawable/emotion_happy"
                app:iconGravity="textStart"
                app:iconPadding="24dp"
                app:iconSize="45dp"
                app:iconTint="@null"
                app:cornerRadius="35dp"/>

            <!-- Sad Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/sadBtn"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:layout_marginBottom="16dp"
                android:backgroundTint="@null"
                android:background="@drawable/bg_sad_btn"
                android:text="Sad"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:textStyle="bold"
                app:icon="@drawable/emotion_sad"
                app:iconGravity="textStart"
                app:iconPadding="24dp"
                app:iconSize="45dp"
                app:iconTint="@null"
                app:cornerRadius="35dp"/>

            <!-- Angry Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/angryBtn"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:layout_marginBottom="16dp"
                android:backgroundTint="@null"
                android:background="@drawable/bg_angry_btn"
                android:text="Angry"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:textStyle="bold"
                app:icon="@drawable/emotion_angry"
                app:iconGravity="textStart"
                app:iconPadding="24dp"
                app:iconSize="45dp"
                app:iconTint="@null"
                app:cornerRadius="35dp"/>

            <!-- Calm Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/calmBtn"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:layout_marginBottom="16dp"
                android:backgroundTint="@null"
                android:background="@drawable/bg_calm_btn"
                android:text="Calm"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:textStyle="bold"
                app:icon="@drawable/emotion_calm"
                app:iconGravity="textStart"
                app:iconPadding="24dp"
                app:iconSize="45dp"
                app:iconTint="@null"
                app:cornerRadius="35dp"/>

            <!-- Anxious Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/anxiousBtn"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:layout_marginBottom="24dp"
                android:backgroundTint="@null"
                android:background="@drawable/bg_anxious_btn"
                android:text="Anxious"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:textStyle="bold"
                app:icon="@drawable/emotion_scared"
                app:iconGravity="textStart"
                app:iconPadding="24dp"
                app:iconSize="45dp"
                app:iconTint="@null"
                app:cornerRadius="35dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Add custom emotion"
                android:textColor="#757575"
                android:textSize="16sp"
                android:layout_marginBottom="8dp"/>

            <EditText
                android:id="@+id/customEmotionText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Type feeling..."
                android:background="@drawable/edit_text_background"
                android:padding="12dp"
                android:layout_marginBottom="16dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/customEmotionBtn"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginBottom="12dp"
                android:backgroundTint="@null"
                android:background="@drawable/bg_add_btn"
                android:text="Add Emotion"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold"
                app:cornerRadius="30dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/deleteEmotionBtn"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:backgroundTint="#FF5252"
                android:text="Delete Emotion History"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                app:cornerRadius="30dp"/>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>