<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F8FF">

    <!-- Top App Bar -->
    <View
        android:id="@+id/topBarBg"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="#1A1A1A"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/backBtn"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="8dp"
        android:padding="12dp"
        android:src="@drawable/ic_arrow_back"
        app:layout_constraintBottom_toBottomOf="@id/topBarBg"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/topBarBg"
        app:tint="@color/white" />

    <TextView
        android:id="@+id/app_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="AutiCare"
        android:textColor="@color/white"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/topBarBg"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/topBarBg" />

    <ImageView
        android:id="@+id/profileBtnTop"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginEnd="8dp"
        android:padding="10dp"
        android:src="@drawable/ic_child_profile"
        app:layout_constraintBottom_toBottomOf="@id/topBarBg"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/topBarBg"
        app:tint="@color/white" />

    <!-- Star Counter Section -->
    <LinearLayout
        android:id="@+id/starCounter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@drawable/edit_text_background"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp"
        android:paddingVertical="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topBarBg">

        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_star"
            app:tint="#FFC107" />

        <TextView
            android:id="@+id/star_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="0 Stars"
            android:textColor="#1A237E"
            android:textSize="24sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/starCounter">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Progress Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Game Progress"
                android:textColor="#333333"
                android:textSize="18sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/edit_text_background"
                android:backgroundTint="#FFFFFF"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:id="@+id/progressEmotion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Emotion Match: ☆☆☆☆☆"
                    android:textColor="#555555"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/progressColorShape"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Color &amp; Shape: ☆☆☆☆☆"
                    android:textColor="#555555"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/progressSound"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Sound Identify: ☆☆☆☆☆"
                    android:textColor="#555555"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/progressMemory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Memory Flip: ☆☆☆☆☆"
                    android:textColor="#555555"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/progressHabit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Good/Bad Habit: ☆☆☆☆☆"
                    android:textColor="#555555"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/progressObject"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Object Finder: ☆☆☆☆☆"
                    android:textColor="#555555"
                    android:textSize="16sp" />
            </LinearLayout>

            <!-- Sticker Grid Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Sticker Collection"
                android:textColor="#333333"
                android:textSize="18sp"
                android:textStyle="bold" />

            <GridLayout
                android:id="@+id/stickerGrid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:columnCount="3"
                android:alignmentMode="alignMargins">

                <ImageView
                    android:id="@+id/stickerRainbow"
                    android:layout_width="0dp"
                    android:layout_height="90dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:background="#F5F5F5"
                    android:padding="12dp"
                    android:src="@drawable/sticker_rainbow" />

                <ImageView
                    android:id="@+id/stickerPuppy"
                    android:layout_width="0dp"
                    android:layout_height="90dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:background="#F5F5F5"
                    android:padding="12dp"
                    android:src="@drawable/sticker_puppy" />

                <ImageView
                    android:id="@+id/stickerCar"
                    android:layout_width="0dp"
                    android:layout_height="90dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:background="#F5F5F5"
                    android:padding="12dp"
                    android:src="@drawable/sticker_car" />

                <ImageView
                    android:id="@+id/stickerStar"
                    android:layout_width="0dp"
                    android:layout_height="90dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:background="#F5F5F5"
                    android:padding="12dp"
                    android:src="@drawable/sticker_star" />

                <ImageView
                    android:id="@+id/stickerCat"
                    android:layout_width="0dp"
                    android:layout_height="90dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:background="#F5F5F5"
                    android:padding="12dp"
                    android:src="@drawable/sticker_cat" />

                <ImageView
                    android:id="@+id/stickerApple"
                    android:layout_width="0dp"
                    android:layout_height="90dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:background="#F5F5F5"
                    android:padding="12dp"
                    android:src="@drawable/sticker_apple" />
            </GridLayout>

            <!-- Special Prize Section -->
            <TextView
                android:id="@+id/tvSpecialPrizeTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Special Rewards"
                android:textColor="#333333"
                android:textSize="18sp"
                android:textStyle="bold" />

            <androidx.cardview.widget.CardView
                android:id="@+id/cvSpecialReward"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">

                <ImageView
                    android:id="@+id/ivSpecialReward"
                    android:layout_width="match_parent"
                    android:layout_height="180dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/reward_knock_door" />
            </androidx.cardview.widget.CardView>

            <!-- Badge Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="My Badges"
                android:textColor="#333333"
                android:textSize="18sp"
                android:textStyle="bold" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingVertical="4dp">

                    <ImageView
                        android:id="@+id/badgeFirstStep"
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:layout_marginEnd="12dp"
                        android:src="@drawable/badge_first_step" />

                    <ImageView
                        android:id="@+id/badgeEmotionMaster"
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:layout_marginEnd="12dp"
                        android:src="@drawable/badge_emotion_master" />

                    <ImageView
                        android:id="@+id/badgeHabitStar"
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:layout_marginEnd="12dp"
                        android:src="@drawable/badge_habit_star" />

                    <ImageView
                        android:id="@+id/badgeFocusChampion"
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:layout_marginEnd="12dp"
                        android:src="@drawable/badge_focus_champion" />
                </LinearLayout>
            </HorizontalScrollView>

            <!-- Treasure Chest Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingBottom="32dp">

                <ImageView
                    android:id="@+id/ivTreasureChest"
                    android:layout_width="160dp"
                    android:layout_height="160dp"
                    android:src="@drawable/treasure_chest" />

                <TextView
                    android:id="@+id/tvChestStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Complete tasks to open!"
                    android:textColor="#757575"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>